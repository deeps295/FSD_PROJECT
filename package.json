{
  "name": "employee-management",
  "version": "1.0.0",
  "description": "Employee Attendance & Leave Management System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"cd client && npm start\" \"cd server && npm run dev\"",
    "build": "cd client && npm run build && cd ../server && npm run build",
    "start:frontend": "cd client && npm start",
    "start:backend": "cd server && npm start",
    "dev:backend": "cd server && npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@netlify/functions": "^2.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.2",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
